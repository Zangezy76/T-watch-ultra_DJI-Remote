# Normalize line endings: store everything as LF in the repository.
# Git auto-detects text vs binary, and checks out LF on all platforms.
* text=auto eol=lf

# --- Source / text files (explicit, just to be safe) ---
*.c       text eol=lf
*.h       text eol=lf
*.cpp     text eol=lf
*.hpp     text eol=lf
*.ino     text eol=lf
*.py      text eol=lf
*.sh      text eol=lf
*.md      text eol=lf
*.txt     text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.js      text eol=lf
*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.csv     text eol=lf
*.cmake   text eol=lf
*.lock    text eol=lf
*.clangd  text eol=lf
CMakeLists.txt text eol=lf
sdkconfig*     text eol=lf
Kconfig*       text eol=lf

# Shell scripts must always be LF (executable correctness)
*.sh      text eol=lf

# --- Binary files: never normalize ---
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.bmp     binary
*.bin     binary
*.elf     binary
*.a       binary
*.o       binary
*.zip     binary
*.gz      binary
*.docx    binary
*.pdf     binary
